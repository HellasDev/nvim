  },

  // While-style loop
  "While loop": {
    "prefix": "while",
    "body": [
      "for ${1:condition} {",
      "\t${2:// loop body}",
      "}"
    ],
    "description": "While-style loop"
  },

  // Infinite loop
  "Infinite loop": {
    "prefix": "infinite",
    "body": [
      "for {",
      "\t${1:// infinite loop body}",
      "\t// use break to exit",
      "}"
    ],
    "description": "Άπειρος βρόχος"
  },

  // Array declaration - βασικές δομές δεδομένων
  "Array": {
    "prefix": "array",
    "body": [
      "${1:arr} := [${2:5}]${3:int}{${4:1, 2, 3, 4, 5}}"
    ],
    "description": "Δήλωση array"
  },

  // Slice declaration - πιο συνηθισμένο από arrays
  "Slice": {
    "prefix": "slice",
    "body": [
      "${1:slice} := []${2:int}{${3:1, 2, 3}}"
    ],
    "description": "Δήλωση slice"
  },

  // Map declaration - key-value pairs
  "Map": {
    "prefix": "map",
    "body": [
      "${1:m} := map[${2:string}]${3:int}{",
      "\t\"${4:key1}\": ${5:value1},",
      "\t\"${6:key2}\": ${7:value2},",
      "}"
    ],
    "description": "Δήλωση map"
  },

  // Make slice με capacity
  "Make slice": {
    "prefix": "makeslice",
    "body": [
      "${1:slice} := make([]${2:int}, ${3:length}, ${4:capacity})"
    ],
    "description": "Δημιουργία slice με make"
  },

  // Make map
  "Make map": {
    "prefix": "makemap",
    "body": [
      "${1:m} := make(map[${2:string}]${3:int})"
    ],
    "description": "Δημιουργία map με make"
  },

  // Append to slice - συνηθισμένη λειτουργία
  "Append slice": {
    "prefix": "append",
    "body": [
