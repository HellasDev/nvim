{
  // ===================================================================
  // Go Snippets Collection - Συλλογή Go αποσπασμάτων κώδικα
  // ===================================================================
  // Περιλαμβάνει snippets για όλες τις συνήθεις Go κατασκευές:
  // • Error handling patterns με διάφορες προσεγγίσεις
  // • HTTP server και handler functions για web development
  // • Struct και interface definitions με JSON tags
  // • Testing utilities (unit tests, benchmarks, table tests)
  // • Concurrency patterns (goroutines, channels, select)
  // • Context handling για cancellation και timeouts
  // • JSON marshaling/unmarshaling με error handling
  // • Logging και debugging utilities
  // ===================================================================

  // Βασικό error handling pattern - το πιο συνηθισμένο στη Go
  "Error handling": {
    "prefix": "iferr",
    "body": [
      "if err != nil {",
      "\treturn ${1:nil, }err",
      "}"
    ],
    "description": "Βασικός έλεγχος σφάλματος"
  },

  // Error handling με log.Fatal - για κρίσιμα σφάλματα που τερματίζουν το πρόγραμμα
  "Error handling with log": {
    "prefix": "iferrl",
    "body": [
      "if err != nil {",
      "\tlog.Fatal(err)",
      "}"
    ],
    "description": "Έλεγχος σφάλματος με log.Fatal"
  },

  // Error wrapping με custom μήνυμα - για καλύτερη διαγνωστική πληροφορία
  "Error handling with custom message": {
    "prefix": "iferrm",
    "body": [
      "if err != nil {",
      "\treturn ${1:nil, }fmt.Errorf(\"${2:error message}: %w\", err)",
      "}"
    ],
    "description": "Έλεγχος σφάλματος με προσαρμοσμένο μήνυμα"
  },

  // HTTP handler function - βασική δομή για web endpoints
  "HTTP handler": {
    "prefix": "httphandler",
    "body": [
      "func ${1:handlerName}(w http.ResponseWriter, r *http.Request) {",
      "\t${2:// handler logic}",
      "}"
    ],
    "description": "Συνάρτηση HTTP handler"
  },

  // Πλήρης HTTP server - έτοιμο template για web εφαρμογή
  "HTTP server": {
    "prefix": "httpserver",
    "body": [
      "package main",
      "",
      "import (",
      "\t\"log\"",
      "\t\"net/http\"",
      ")",
      "",
      "func main() {",
      "\tmux := http.NewServeMux()",
      "\tmux.HandleFunc(\"${1:/}\", ${2:handler})",
      "",
      "\tlog.Println(\"Server starting on :${3:8080}\")",
      "\tlog.Fatal(http.ListenAndServe(\":${3:8080}\", mux))",
      "}"
    ],
    "description": "Βασικός HTTP server"
  },

  // Struct με JSON tags - για API responses και database mapping
  "Struct with JSON tags": {
    "prefix": "structjson",
    "body": [
      "type ${1:StructName} struct {",
      "\t${2:Field} ${3:string} `json:\"${4:field}\"`",
      "}"
    ],
    "description": "Struct με JSON tags"
  },

  // Interface definition - για abstraction και dependency injection
  "Interface": {
    "prefix": "interface",
    "body": [
      "type ${1:InterfaceName} interface {",
      "\t${2:MethodName}(${3:params}) ${4:returnType}",
      "}"
    ],
    "description": "Ορισμός interface"
  },

  // Method definition - μέθοδος για struct types
  "Method": {
    "prefix": "method",
    "body": [
      "func (${1:receiver} ${2:ReceiverType}) ${3:MethodName}(${4:params}) ${5:returnType} {",
      "\t${6:// method body}",
      "}"
    ],
    "description": "Ορισμός μεθόδου"
  },

  // Unit test function - βασική δομή για testing
  "Test function": {
    "prefix": "test",
    "body": [
      "func Test${1:FunctionName}(t *testing.T) {",
      "\t${2:// test implementation}",
      "}"
    ],
    "description": "Συνάρτηση test"
  },

  // Benchmark test - για performance measurements
  "Benchmark function": {
    "prefix": "benchmark",
    "body": [
      "func Benchmark${1:FunctionName}(b *testing.B) {",
      "\tfor i := 0; i < b.N; i++ {",
      "\t\t${2:// benchmark code}",
      "\t}",
      "}"
    ],
    "description": "Συνάρτηση benchmark"
  },

  // Table-driven test - best practice για πολλαπλά test cases
  "Table driven test": {
    "prefix": "tabletest",
    "body": [
      "func Test${1:FunctionName}(t *testing.T) {",
      "\ttests := []struct {",
      "\t\tname string",
      "\t\t${2:input} ${3:inputType}",
      "\t\twant ${4:outputType}",
      "\t\twantErr bool",
      "\t}{",
      "\t\t{",
      "\t\t\tname: \"${5:test case}\",",
      "\t\t\t${2:input}: ${6:inputValue},",
      "\t\t\twant: ${7:expectedOutput},",
      "\t\t\twantErr: false,",
      "\t\t},",
      "\t}",
      "",
      "\tfor _, tt := range tests {",
      "\t\tt.Run(tt.name, func(t *testing.T) {",
      "\t\t\tgot, err := ${8:functionCall}(tt.${2:input})",
      "\t\t\tif (err != nil) != tt.wantErr {",
      "\t\t\t\tt.Errorf(\"${8:functionCall}() error = %v, wantErr %v\", err, tt.wantErr)",
      "\t\t\t\treturn",
      "\t\t\t}",
      "\t\t\tif got != tt.want {",
      "\t\t\t\tt.Errorf(\"${8:functionCall}() = %v, want %v\", got, tt.want)",
      "\t\t\t}",
      "\t\t})",
      "\t}",
      "}"
    ],
    "description": "Table-driven test"
  },

  // Anonymous goroutine - για concurrent execution
  "Goroutine": {
    "prefix": "go",
    "body": [
      "go func() {",
      "\t${1:// goroutine body}",
      "}()"
    ],
    "description": "Ανώνυμη goroutine"
  },

  // Channel creation - για communication μεταξύ goroutines
  "Channel": {
    "prefix": "chan",
    "body": [
      "${1:ch} := make(chan ${2:type}${3:, ${4:buffer}})"
    ],
    "description": "Δημιουργία channel"
  },

  // Select statement - για non-blocking channel operations
  "Select statement": {
    "prefix": "select",
    "body": [
      "select {",
      "case ${1:value} := <-${2:channel}:",
      "\t${3:// handle value}",
      "case <-${4:timeout}:",
      "\t${5:// handle timeout}",
      "default:",
      "\t${6:// default case}",
      "}"
    ],
    "description": "Select statement"
  },

  // Context με timeout - για cancellation και timeouts
  "Context with timeout": {
    "prefix": "ctxtimeout",
    "body": [
      "ctx, cancel := context.WithTimeout(context.Background(), ${1:time.Second*30})",
      "defer cancel()"
    ],
    "description": "Context με timeout"
  },

  // Context με manual cancellation
  "Context with cancel": {
    "prefix": "ctxcancel",
    "body": [
      "ctx, cancel := context.WithCancel(context.Background())",
      "defer cancel()"
    ],
    "description": "Context με ακύρωση"
  },

  // For range loop - για iteration σε collections
  "For range": {
    "prefix": "forr",
    "body": [
      "for ${1:key}, ${2:value} := range ${3:collection} {",
      "\t${4:// loop body}",
      "}"
    ],
    "description": "For range loop"
  },

  // Formatted logging - για debugging και monitoring
  "Log info": {
    "prefix": "loginfo",
    "body": [
      "log.Printf(\"${1:message}: %+v\", ${2:variable})"
    ],
    "description": "Log πληροφοριών με formatting"
  },

  // JSON encoding με error handling
  "JSON marshal": {
    "prefix": "jsonmarshal",
    "body": [
      "data, err := json.Marshal(${1:object})",
      "if err != nil {",
      "\treturn ${2:nil, }err",
      "}"
    ],
    "description": "JSON marshal με έλεγχο σφάλματος"
  },

  // JSON decoding με error handling
  "JSON unmarshal": {
    "prefix": "jsonunmarshal",
    "body": [
      "var ${1:object} ${2:Type}",
      "err := json.Unmarshal(${3:data}, &${1:object})",
      "if err != nil {",
      "\treturn ${4:nil, }err",
      "}"
    ],
    "description": "JSON unmarshal με έλεγχο σφάλματος"
  },

  // ===================================================================
  // BEGINNER-FRIENDLY SNIPPETS - Snippets για αρχάριους
  // ===================================================================

  // Βασικό Hello World program - για εκμάθηση της Go
  "Hello World": {
    "prefix": "hello",
    "body": [
      "package main",
      "",
      "import \"fmt\"",
      "",
      "func main() {",
      "\tfmt.Println(\"Hello, World!\")",
      "}"
    ],
    "description": "Βασικό Hello World πρόγραμμα"
  },

  // Βασική συνάρτηση - template για οποιαδήποτε function
  "Basic function": {
    "prefix": "func",
    "body": [
      "func ${1:functionName}(${2:params}) ${3:returnType} {",
      "\t${4:// function body}",
      "\treturn ${5:value}",
      "}"
    ],
    "description": "Βασική συνάρτηση"
  },

  // Variable declarations - διάφοροι τρόποι δήλωσης μεταβλητών
  "Variable declaration": {
    "prefix": "var",
    "body": [
      "var ${1:varName} ${2:type} = ${3:value}"
    ],
    "description": "Δήλωση μεταβλητής"
  },

  // Short variable declaration - ο πιο συνηθισμένος τρόπος
  "Short variable": {
    "prefix": "sv",
    "body": [
