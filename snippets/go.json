  },

  // ===================================================================
  // FILE OPERATIONS - Λειτουργίες αρχείων
  // ===================================================================

  // Διάβασμα αρχείου - βασική file I/O
  "Read file": {
    "prefix": "readfile",
    "body": [
      "data, err := os.ReadFile(\"${1:filename.txt}\")",
      "if err != nil {",
      "\tlog.Fatal(err)",
      "}",
      "fmt.Println(string(data))"
    ],
    "description": "Διάβασμα ολόκληρου αρχείου"
  },

  // Γράψιμο αρχείου
  "Write file": {
    "prefix": "writefile",
    "body": [
      "data := []byte(\"${2:Hello, World!}\")",
      "err := os.WriteFile(\"${1:filename.txt}\", data, 0644)",
      "if err != nil {",
      "\tlog.Fatal(err)",
      "}"
    ],
    "description": "Γράψιμο αρχείου"
  },

  // Άνοιγμα αρχείου για reading/writing
  "Open file": {
    "prefix": "openfile",
    "body": [
      "file, err := os.Open(\"${1:filename.txt}\")",
      "if err != nil {",
      "\tlog.Fatal(err)",
      "}",
      "defer file.Close()",
      "",
      "${2:// work with file}"
    ],
    "description": "Άνοιγμα αρχείου"
  },

  // Create new file
  "Create file": {
    "prefix": "createfile",
    "body": [
      "file, err := os.Create(\"${1:filename.txt}\")",
      "if err != nil {",
      "\tlog.Fatal(err)",
      "}",
      "defer file.Close()",
      "",
      "${2:// write to file}"
    ],
    "description": "Δημιουργία νέου αρχείου"
  },

  // Check if file exists
  "Check file exists": {
    "prefix": "fileexists",
    "body": [
      "if _, err := os.Stat(\"${1:filename.txt}\"); os.IsNotExist(err) {",
      "\tfmt.Println(\"File does not exist\")",
      "} else {",
      "\tfmt.Println(\"File exists\")",
      "}"
    ],
    "description": "Έλεγχος ύπαρξης αρχείου"
  },

