  // String formatting με Printf
  "Printf": {
    "prefix": "printf",
    "body": [
      "fmt.Printf(\"${1:%s}: %d\\n\", ${2:string}, ${3:number})"
    ],
    "description": "Formatted printing"
  },

  // String concatenation
  "String concat": {
    "prefix": "strconcat",
    "body": [
      "${1:result} := ${2:str1} + ${3:str2}"
    ],
    "description": "Συνένωση strings"
  },

  // String split
  "String split": {
    "prefix": "strsplit",
    "body": [
      "${1:parts} := strings.Split(${2:str}, \"${3:,}\")"
    ],
    "description": "Διαχωρισμός string"
  },

  // String join
  "String join": {
    "prefix": "strjoin",
    "body": [
      "${1:result} := strings.Join(${2:slice}, \"${3:,}\")"
    ],
    "description": "Ένωση strings από slice"
  },

  // String contains
  "String contains": {
    "prefix": "strcontains",
    "body": [
      "if strings.Contains(${1:str}, \"${2:substring}\") {",
      "\t${3:// string contains substring}",
      "}"
    ],
    "description": "Έλεγχος αν string περιέχει substring"
  },

  // ===================================================================
  // HTTP CLIENT - HTTP requests για APIs
  // ===================================================================

  // GET request - βασικό HTTP client
  "HTTP GET": {
    "prefix": "httpget",
    "body": [
      "resp, err := http.Get(\"${1:https://api.example.com}\")",
      "if err != nil {",
      "\tlog.Fatal(err)",
      "}",
      "defer resp.Body.Close()",
      "",
      "body, err := io.ReadAll(resp.Body)",
      "if err != nil {",
      "\tlog.Fatal(err)",
      "}",
      "",
      "fmt.Println(string(body))"
    ],
    "description": "HTTP GET request"
  },

  // POST request με JSON
  "HTTP POST JSON": {
    "prefix": "httppost",
    "body": [
      "data := map[string]interface{}{",
      "\t\"${2:key}\": \"${3:value}\",",
      "}",
      "",
      "jsonData, err := json.Marshal(data)",
      "if err != nil {",
      "\tlog.Fatal(err)",
      "}",
      "",
      "resp, err := http.Post(",
      "\t\"${1:https://api.example.com}\",",
      "\t\"application/json\",",
      "\tbytes.NewBuffer(jsonData),",
      ")",
      "if err != nil {",
      "\tlog.Fatal(err)",
      "}",
      "defer resp.Body.Close()"
    ],
    "description": "HTTP POST με JSON data"
  },

  // ===================================================================
  // ENVIRONMENT & CONFIGURATION
  // ===================================================================

  // Read environment variable
  "Environment variable": {
    "prefix": "env",
    "body": [
      "${1:value} := os.Getenv(\"${2:ENV_VAR}\")",
      "if ${1:value} == \"\" {",
      "\t${1:value} = \"${3:default_value}\"",
      "}"
    ],
    "description": "Διάβασμα environment variable"
  },

  // Set environment variable
  "Set environment": {
    "prefix": "setenv",
    "body": [
      "err := os.Setenv(\"${1:ENV_VAR}\", \"${2:value}\")",
      "if err != nil {",
      "\tlog.Fatal(err)",
      "}"
    ],
    "description": "Ορισμός environment variable"
  },

  // Command line arguments
  "Command line args": {
    "prefix": "args",
    "body": [
      "if len(os.Args) < ${1:2} {",
      "\tfmt.Println(\"Usage: program ${2:argument}\")",
      "\tos.Exit(1)",
      "}",
      "",
      "${3:arg} := os.Args[1]"
    ],
    "description": "Χειρισμός command line arguments"
  },

  // ===================================================================
  // TIME OPERATIONS - Χρόνος και ημερομηνίες
  // ===================================================================

  // Current time
  "Current time": {
    "prefix": "now",
    "body": [
      "${1:now} := time.Now()",
      "fmt.Println(${1:now}.Format(\"2006-01-02 15:04:05\"))"
    ],
    "description": "Τρέχουσα ημερομηνία και ώρα"
  },

  // Sleep για delay
  "Sleep": {
    "prefix": "sleep",
    "body": [
      "time.Sleep(${1:time.Second * 2})"
    ],
    "description": "Παύση εκτέλεσης"
  },

  // Timer για delayed execution
  "Timer": {
    "prefix": "timer",
    "body": [
      "timer := time.NewTimer(${1:time.Second * 5})",
      "<-timer.C",
      "fmt.Println(\"Timer expired\")"
    ],
    "description": "Timer για delayed execution"
  },

  // ===================================================================
  // BASIC STRUCTS & POINTERS - Βασικές έννοιες
  // ===================================================================

  // Simple struct
  "Simple struct": {
    "prefix": "struct",
    "body": [
      "type ${1:Person} struct {",
      "\t${2:Name} ${3:string}",
      "\t${4:Age}  ${5:int}",
      "}"
    ],
    "description": "Απλό struct"
  },

  // Struct constructor function
  "New struct": {
    "prefix": "newstruct",
    "body": [
      "func New${1:Person}(${2:name string, age int}) *${1:Person} {",
      "\treturn &${1:Person}{",
      "\t\t${3:Name}: ${2:name},",
      "\t\t${4:Age}:  ${2:age},",
      "\t}",
      "}"
    ],
    "description": "Constructor function για struct"
  },

  // Pointer declaration
  "Pointer": {
    "prefix": "pointer",
    "body": [
      "${1:ptr} := &${2:variable}",
      "fmt.Println(*${1:ptr}) // dereference"
    ],
    "description": "Pointer declaration και dereference"
  }
}