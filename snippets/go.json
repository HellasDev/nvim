      "\t${6:// default code}",
      "}"
    ],
    "description": "Switch statement"
  },

  // Basic for loop - βασικός τρόπος επανάληψης
  "For loop": {
    "prefix": "for",
    "body": [
      "for ${1:i} := ${2:0}; ${1:i} < ${3:10}; ${1:i}++ {",
