    ],
    "description": "Σύντομη δήλωση μεταβλητής"
  },

  // Constant declaration
  "Constant": {
    "prefix": "const",
    "body": [
      "const ${1:constName} ${2:type} = ${3:value}"
    ],
    "description": "Δήλωση σταθεράς"
  },

  // Basic if statement - βασική conditionals
  "If statement": {
    "prefix": "if",
    "body": [
      "if ${1:condition} {",
